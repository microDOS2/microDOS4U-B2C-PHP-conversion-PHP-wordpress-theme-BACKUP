{
  "$schema": "https://schemas.wp.org/wp/6.7/theme.json",
  "version": 3,
  "title": "microDOS4U",
  "settings": {
    "appearanceTools": true,
    "color": {
      "defaultPalette": false,
      "palette": [
        { "slug": "bg-dark", "color": "#0a0514", "name": "Background Dark" },
        { "slug": "bg-card", "color": "#150f24", "name": "Card Background" },
        { "slug": "brand-micro", "color": "#44f80c", "name": "Brand Green" },
        { "slug": "brand-dos", "color": "#9a02d0", "name": "Brand Purple" },
        { "slug": "brand-two", "color": "#ff66c4", "name": "Brand Pink" },
        { "slug": "text-primary", "color": "#d1d5db", "name": "Primary Text" },
        { "slug": "text-heading", "color": "#ffffff", "name": "Heading Text" },
        { "slug": "text-muted", "color": "#94a3b8", "name": "Muted Text" },
        { "slug": "border", "color": "#1a1329", "name": "Border" },
        { "slug": "accent-blue", "color": "#38bdf8", "name": "Accent Blue" },
        { "slug": "accent-purple", "color": "#8b5cf6", "name": "Accent Purple" }
      ]
    },
    "layout": {
      "contentSize": "896px",
      "wideSize": "1280px"
    },
    "spacing": {
      "units": ["px", "em", "rem", "vh", "vw", "%"],
      "spacingScale": {
        "operator": "*",
        "increment": 1.5,
        "steps": 7,
        "mediumStep": 4,
        "unit": "rem"
      }
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "'Inter', sans-serif",
          "name": "Inter",
          "slug": "inter",
          "fontFace": [
            {
              "fontFamily": "Inter",
              "fontWeight": "400 800",
              "fontStyle": "normal",
              "fontDisplay": "swap",
              "src": ["file:./fonts/inter-1.woff2"]
            }
          ]
        }
      ],
      "fontSizes": [
        { "slug": "xs", "size": "0.75rem", "name": "Extra Small" },
        { "slug": "sm", "size": "0.875rem", "name": "Small" },
        { "slug": "base", "size": "1rem", "name": "Base" },
        { "slug": "lg", "size": "1.125rem", "name": "Large" },
        { "slug": "xl", "size": "1.25rem", "name": "Extra Large" },
        { "slug": "2xl", "size": "1.5rem", "name": "2X Large" },
        { "slug": "3xl", "size": "2rem", "name": "3X Large" },
        { "slug": "4xl", "size": "2.5rem", "name": "4X Large" }
      ]
    }
  },
  "styles": {
    "color": {
      "background": "#0a0514",
      "text": "#d1d5db"
    },
    "elements": {
      "heading": {
        "color": {
          "text": "#ffffff"
        },
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--inter)",
          "fontWeight": "700",
          "lineHeight": "1.3"
        }
      },
      "link": {
        "color": {
          "text": "#38bdf8"
        },
        ":hover": {
          "color": {
            "text": "#44f80c"
          }
        }
      }
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--inter)",
      "lineHeight": "1.6"
    },
    "blocks": {
      "core/button": {
        "color": {
          "background": "#44f80c",
          "text": "#0a0514"
        },
        "border": {
          "radius": "0.5rem"
        },
        "typography": {
          "fontWeight": "700"
        }
      },
      "core/group": {
        "color": {
          "background": "#150f24"
        },
        "border": {
          "color": "#1a1329",
          "width": "1px",
          "radius": "0.75rem"
        }
      }
    }
  },
  "templateParts": [
    {
      "name": "header",
      "title": "Header",
      "area": "header"
    },
    {
      "name": "footer",
      "title": "Footer",
      "area": "footer"
    }
  ],
  "customTemplates": [
    {
      "name": "page-affiliate-area",
      "title": "Affiliate Area",
      "postTypes": ["page"]
    }
  ]
}
